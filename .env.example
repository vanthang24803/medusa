DATABASE_URL=postgres://postgres:secret@localhost:5432/ecommerce?sslmode=disable
# DATABASE_REPLICA_URL=  # set when read replica (master/slave) is present
REDIS_URL=redis://localhost:6379
# Upload / Object Storage Configuration
# Providers: minio, r2, s3
UPLOAD_PROVIDER=minio
UPLOAD_ENDPOINT=localhost:9000
UPLOAD_ACCESS_KEY=minioadmin
UPLOAD_SECRET_KEY=minioadmin
UPLOAD_REGION=
UPLOAD_SSL=false
UPLOAD_PUBLIC_URL=
JWT_SECRET=change-me-in-production
PORT=8080
ENV=development

# Cache Configuration
# Providers: redis, inmemory
CACHE_PROVIDER=inmemory
CACHE_URL=redis://localhost:6379

# Queue Configuration
# Providers: inmemory, rabbitmq, kafka, redis
QUEUE_PROVIDER=inmemory
QUEUE_URL=

# Events Configuration
# Providers: log, inmemory, redis, kafka, rabbitmq
EVENTS_PROVIDER=log
EVENTS_URL=

# Monitoring Configuration
# Providers: console, prometheus, datadog, sentry
MONITORING_PROVIDER=console
MONITORING_DSN=
MONITORING_ENDPOINT=

# Payment Configuration
# Providers: stripe, paypal, momo, vnpay
PAYMENT_PROVIDER=stripe
PAYMENT_API_KEY=
PAYMENT_CLIENT_ID=
PAYMENT_MERCHANT_ID=
PAYMENT_SECRET_KEY=
PAYMENT_SANDBOX=true

# Search Configuration
# Providers: meilisearch, elasticsearch, algolia, inmemory
SEARCH_PROVIDER=inmemory
SEARCH_URL=
SEARCH_API_KEY=

